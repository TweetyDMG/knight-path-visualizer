<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootPane" alignment="TOP_CENTER" prefHeight="350.0" prefWidth="280.0" spacing="5.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <children>
        <HBox alignment="CENTER_RIGHT" prefHeight="30.0" spacing="5.0">
            <children>
                <Button fx:id="minimizeButton" mnemonicParsing="false" styleClass="window-button" text="_" />
                <Button fx:id="closeButton" mnemonicParsing="false" styleClass="window-button" text="X" />
            </children>
            <padding>
                <Insets right="5.0" top="5.0" />
            </padding>
            <VBox.margin>
                <Insets bottom="5.0"/>
            </VBox.margin>
        </HBox>

        <ListView fx:id="movesList" VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" />
            </VBox.margin>
        </ListView>
    </children>
    <padding>
        <Insets />
    </padding>
</VBox>