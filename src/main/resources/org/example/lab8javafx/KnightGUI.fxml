<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="mainRootPane" alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.lab8javafx.KnightController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <children>
        <AnchorPane fx:id="boardContainer" maxHeight="480.0" minHeight="480.0" prefHeight="480.0" prefWidth="600.0" />
        <HBox alignment="CENTER" spacing="15" styleClass="controls-pane">
            <children>
                <VBox alignment="CENTER" spacing="5">
                    <children>
                        <Label styleClass="label" text="Глубина:" />
                        <Spinner fx:id="maxMovesSpinner" initialValue="2" prefWidth="80.0" />
                        <Button fx:id="calculateButton" text="Рассчитать" />
                    </children>
                </VBox>
                <VBox alignment="CENTER" prefHeight="78.0" prefWidth="162.0" spacing="5.0">
                    <children>
                        <Label text=" " />
                        <Button fx:id="showPathButton" prefHeight="34.0" prefWidth="161.0" text="Показать путь">
                            <VBox.margin>
                                <Insets />
                            </VBox.margin>
                        </Button>
                        <Button fx:id="openMovesWindowButton" prefHeight="34.0" prefWidth="162.0" text="Открыть окно ходов">
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin></Button>
                    </children>
                    <HBox.margin>
                        <Insets bottom="30.0" />
                    </HBox.margin>
                </VBox>
                <VBox alignment="CENTER" spacing="5">
                    <children>
                        <HBox alignment="CENTER" spacing="5">
                            <children>
                                <Label prefHeight="20.0" prefWidth="73.0" styleClass="label" text="Строк:" />
                                <Spinner fx:id="rowsSpinner" initialValue="8" prefHeight="27.0" prefWidth="80.0" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="5">
                            <children>
                                <Label styleClass="label" text="Столбцов:" />
                                <Spinner fx:id="colsSpinner" initialValue="8" prefHeight="27.0" prefWidth="80.0" />
                            </children>
                        </HBox>
                        <Button fx:id="resizeButton" prefHeight="33.0" prefWidth="152.0" text="Изменить размер" />
                        <Button fx:id="clearVisitedButton" prefHeight="33.0" prefWidth="152.0" text="Очистить поле" />
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="10" left="15" right="15" top="10" />
            </padding>
        </HBox>
    </children>
</VBox>
